{
  "name": "acp-agent",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "agent": "bun run src/agent/index.ts",
    "client": "bun run src/client/index.ts",
    "server": "bun run src/web/index.ts",
    "dev": "bun --hot src/web/index.ts",
    "build": "bun build --compile src/main.ts --outfile dist/acp-agent",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/main.ts --outfile dist/acp-agent-linux-x64",
    "build:macos-arm64": "bun build --compile --target=bun-darwin-arm64 src/main.ts --outfile dist/acp-agent-macos-arm64",
    "build:macos-x64": "bun build --compile --target=bun-darwin-x64 src/main.ts --outfile dist/acp-agent-macos-x64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 src/main.ts --outfile dist/acp-agent-windows-x64.exe"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "marked": "^18.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}